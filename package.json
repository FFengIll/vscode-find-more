{
    "name": "find-more",
    "displayName": "find-more",
    "description": "Extend of the build-in find functions",
    "author": "Feng Youzheng",
    "version": "0.25.1203",
    "publisher": "FengYouzheng",
    "license": "MIT",
    "homepage": "https://github.com/FengYouzheng/vscode-find-more.git",
    "repository": {
        "type": "git",
        "url": "https://github.com/FengYouzheng/vscode-find-more.git"
    },
    "bugs": "https://github.com/FengYouzheng/vscode-find-more.git/issues",
    "engines": {
        "vscode": "^1.100.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "find"
    ],
    "activationEvents": [
        "onCommand:findInFile.withText",
        "onCommand:findInFile.withFile"
    ],
    "main": "./out/extension",
    "scripts": {
        "vscode:prepublish": "pnpm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "pnpm run compile && pnpm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^9.1.1",
        "@types/node": "~14.18.63",
        "@types/vscode": "^1.100.0",
        "@typescript-eslint/eslint-plugin": "^8.48.1",
        "@typescript-eslint/parser": "^8.48.1",
        "eslint": "^9.39.1",
        "glob": "^13.0.0",
        "mocha": "^9.2.2",
        "typescript": "^4.9.5"
    },
    "contributes": {
        "menus": {
            "editor/title": [
                {
                    "command": "findInFile.withText",
                    "group": "navigation@1"
                }
            ],
            "explorer/context": [
                {
                    "command": "findInFile.withFile",
                    "group": "Find",
                    "when": "explorerResourceIsFolder!=true"
                }
            ],
            "commandPalette": []
        },
        "commands": [
            {
                "command": "findInFile.withText",
                "title": "Find All",
                "mac": "cmd+k,cmd+k",
                "when": "editorTextFocus"
            },
            {
                "command": "findInFile.withFile",
                "title": "Find All In File"
            },
            {
                "command": "findInFile.clear",
                "title": "Clear"
            }
        ]
    }
}
